{
  "name": "file-manager",
  "private": true,
  "version": "0.1.18",
  "description": "Cross-platform ranger-inspired file manager with native drag-out",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:native": "node -e \"if(process.platform==='darwin'){require('child_process').execSync('make -C native/sharer',{stdio:'inherit'})}else{console.log('build:native: skipped on '+process.platform)}\"",
    "build": "npm run build:native && tsc -b && vite build",
    "start": "npm run dev",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "node --test tests/",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.vivek.breezefile",
    "productName": "Breeze File",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist",
      "dist-electron",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "extraResources": [
        {
          "from": "native/sharer/sharer",
          "to": "sharer"
        },
        {
          "from": "bin/breeze",
          "to": "breeze"
        },
        {
          "from": "bin/breeze.mjs",
          "to": "breeze.mjs"
        }
      ],
      "icon": "build/icon.icns",
      "artifactName": "Breezefile-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSDocumentsFolderUsageDescription": "Breeze File needs access to your Documents folder to browse and manage files.",
        "NSDownloadsFolderUsageDescription": "Breeze File needs access to your Downloads folder to browse and manage files.",
        "NSDesktopFolderUsageDescription": "Breeze File needs access to your Desktop folder to browse and manage files.",
        "NSRemovableVolumesUsageDescription": "Breeze File needs access to removable volumes (USB drives, SD cards) to browse and manage files.",
        "NSNetworkVolumesUsageDescription": "Breeze File needs access to network volumes to browse and manage files.",
        "NSAppleEventsUsageDescription": "Breeze File uses Apple Events to open files in other applications and reveal them in Finder.",
        "NSSystemAdministrationUsageDescription": "Breeze File needs access to system folders to browse and manage files."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    }
  }
}
